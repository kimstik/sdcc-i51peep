+/*-----------------------------------------------------------------*/
+/* operandOffset - check if op1 == op2 + N (symbolic comparison)   */
+/*   Usage: operandOffset(%1 %2 N)                                 */
+/*   Parses two SDCC symbolic addresses and checks if              */
+/*   %1 == %2 + N (same symbol, offset differs by N).              */
+/*   Operands may have # prefix (stripped automatically).           */
+/*-----------------------------------------------------------------*/
+FBYNAME (operandOffset)
+{
+  char *op[3] = {NULL, NULL, NULL};
+  int nOps = 0;
+
+  /* parse arguments: operand1, operand2, offset */
+  {
+    set *operands = setFromConditionArgs (cmdLine, vars);
+    const void *item;
+
+    for (item = setFirstItem (operands); item && nOps < 3; item = setNextItem (operands))
+      op[nOps++] = Safe_strdup ((const char *) item);
+    deleteSet (&operands);
+  }
+
+  if (nOps < 3 || !op[0] || !op[1] || !op[2])
+    {
+      int i; for (i = 0; i < nOps; i++) Safe_free (op[i]);
+      return FALSE;
+    }
+
+  int requestedOffset = (int) strtol (op[2], NULL, 0);
+
+  /* strip # prefix from operands if present */
+  const char *addr1 = op[0];
+  const char *addr2 = op[1];
+  if (*addr1 == '#') addr1++;
+  if (*addr2 == '#') addr2++;
+
+  /* parse both symbolic addresses */
+  char sym1[256], sym2[256];
+  int off1 = 0, off2 = 0;
+  if (!parseSymAddr (addr1, sym1, sizeof (sym1), &off1) ||
+      !parseSymAddr (addr2, sym2, sizeof (sym2), &off2))
+    {
+      int i; for (i = 0; i < 3; i++) Safe_free (op[i]);
+      return FALSE;
+    }
+
+  /* check: same symbol, off1 == off2 + requestedOffset */
+  int match = (!strcmp (sym1, sym2) && off1 == off2 + requestedOffset);
+
+  int i; for (i = 0; i < 3; i++) Safe_free (op[i]);
+  return match;
+}
