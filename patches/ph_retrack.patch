+/*-----------------------------------------------------------------*/
+/* parseSymAddr - parse SDCC symbolic address into (symbol, offset) */
+/*   Handles: "(_sym + 0xNN)", "0xNN", "_sym"                     */
+/*   Returns 1 on success, 0 on parse failure.                    */
+/*-----------------------------------------------------------------*/
+static int
+parseSymAddr (const char *addr, char *sym, size_t symSz, int *off)
+{
+  const char *p = addr;
+
+  *sym = '\0';
+  *off = 0;
+
+  /* skip leading whitespace and opening paren */
+  while (*p == ' ' || *p == '\t') p++;
+  int hasParen = (*p == '(');
+  if (hasParen) p++;
+  while (*p == ' ' || *p == '\t') p++;
+
+  /* pure numeric: 0xNN or decimal */
+  if ((p[0] == '0' && (p[1] == 'x' || p[1] == 'X')) || isdigit ((unsigned char) p[0]))
+    {
+      char *end;
+      long v = strtol (p, &end, 0);
+      while (*end == ' ' || *end == '\t') end++;
+      if (hasParen && *end == ')') end++;
+      if (*end == '\0' || *end == ' ' || *end == '\t' || *end == ';')
+        {
+          *off = (int) v;
+          return 1;
+        }
+      /* not a clean numeric - fall through */
+    }
+
+  /* symbol, optionally followed by " + 0xNN" */
+  const char *symStart = p;
+  while (*p && *p != ' ' && *p != '\t' && *p != '+' && *p != '-' && *p != ')') p++;
+  size_t len = p - symStart;
+  if (len == 0 || len >= symSz) return 0;
+  memcpy (sym, symStart, len);
+  sym[len] = '\0';
+
+  /* optional offset: sign and number may be separated by whitespace */
+  while (*p == ' ' || *p == '\t') p++;
+  if (*p == '+' || *p == '-')
+    {
+      int sign = (*p == '-') ? -1 : 1;
+      p++;
+      while (*p == ' ' || *p == '\t') p++;
+      char *end;
+      long v = strtol (p, &end, 0);
+      *off = (int) (sign * v);
+      p = end;
+    }
+  while (*p == ' ' || *p == '\t') p++;
+  if (hasParen && *p == ')') p++;
+
+  return 1;
+}
