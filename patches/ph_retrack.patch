+/*-----------------------------------------------------------------*/
+/* _mcs51_retrack - re-run register tracking on lineNodes at *head  */
+/*-----------------------------------------------------------------*/
+void
+_mcs51_retrack (lineNode **head)
+{
+  lineNode *pl;
+
+  assert (genLine.lineCurr);
+
+  invalidateAll ();
+
+  for (pl = *head; pl; )
+    {
+      const char *p;
+      lineNode *next = pl->next;
+
+      assert (pl->line);
+      p = pl->line;
+      while (isspace ((unsigned char) *p))
+        p++;
+
+      /* skip empty lines, comments, debug */
+      if (!*p || *p == ';' || pl->isComment || pl->isDebug)
+        { pl = next; continue; }
+
+      /* stop at labels - state unknown from other paths */
+      if (pl->isLabel)
+        break;
+
+      /* stop at unconditional jumps, returns */
+      if (!strncmp (p, "sjmp", 4) || !strncmp (p, "ljmp", 4) ||
+          !strncmp (p, "ajmp", 4) || !strncmp (p, "ret", 3))
+        break;
+
+      /* capture genLine state before rtrackUpdate */
+      lineNode *saved = genLine.lineCurr;
+      int saved_verbose = options.verboseAsm;
+      options.verboseAsm = 0;
+      initGenLineElement ();
+
+      bool deleted = _mcs51_rtrackUpdate (p);
+
+      options.verboseAsm = saved_verbose;
+
+      if (deleted && genLine.lineCurr != saved)
+        {
+          /* rtrackUpdate emitted replacement(s) via emitcode.
+             Splice all appended nodes (saved->next .. lineCurr)
+             into the peephole list, replacing the original line. */
+          lineNode *first_new = saved->next;
+          lineNode *last_new = genLine.lineCurr;
+
+          /* rollback genLine */
+          genLine.lineCurr = saved;
+          saved->next = NULL;
+
+          /* splice chain in place of pl */
+          first_new->prev = pl->prev;
+          if (pl->prev)
+            pl->prev->next = first_new;
+          last_new->next = pl->next;
+          if (pl->next)
+            pl->next->prev = last_new;
+          if (pl == *head)
+            *head = first_new;
+
+          pl = last_new->next;
+        }
+      else if (deleted)
+        {
+          /* rtrackUpdate wants line deleted (no replacement emitted) */
+          if (pl->prev)
+            pl->prev->next = pl->next;
+          if (pl->next)
+            pl->next->prev = pl->prev;
+          if (pl == *head)
+            *head = pl->next;
+          pl = next;
+        }
+      else
+        {
+          pl = next;
+        }
+    }
+}
